<%layout("/layouts/boilerplate") %>
<body>
<div class="row mt-5">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow p-4">
        <h3>Edit your Listing</h3>
        <form method="post" action="/listings/<%=listing._id %>?_method=PUT" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input 
                type="text" 
                name="listing[title]" 
                value="<%=listing.title %>"
                class="form-control"
                required
            />
            <div class="invalid-feedback">Enter title correctly </div>
        </div>

        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" required><%=listing.description %></textarea>    
            <div class="invalid-feedback">Enter correct description </div>       
        </div>
        
        <div class="mb-3">
            <label for="image" class="form-label">Image</label>

            <input 
                type="text" 
                name="listing[image][url]" 
                value="<%= listing.image.url %>"
                placeholder="Leave blank to keep current image"
                class="form-control"
                required
            />
            <div class="invalid-feedback">Enter img url link </div>
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input 
                    name="listing[price]" 
                    value="<%=listing.price %>"
                    class="form-control"
                    required
                />
                <div class="invalid-feedback">Enter valid price </div>
            </div>

            <div class="mb-3 col-md-4">
                <label for="country" class="form-label">Country</label>
                <input 
                    type="text" 
                    name="listing[country]" 
                    value="<%=listing.country %>"
                    class="form-control"
                    required
                />
                <div class="invalid-feedback">Enter your country</div>
            </div>
        </div>

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input 
                type="text" 
                name="listing[location]" 
                value="<%=listing.location %>"
                class="form-control"
                required
            />
            <div class="invalid-feedback">Enter your location</div>
        </div>

        <button type="submit" class="btn btn-dark mt-2">Edit</button>
    </form>
    </div>
    </div>
</div>
<script src="/js/script.js"></script>
</body>
</html>