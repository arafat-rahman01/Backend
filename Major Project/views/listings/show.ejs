<%layout("/layouts/boilerplate") %>
<body>
    <h3>Listings Deatils:</h3>
    <ul>
        <li><%=listing.title %></li>
        <li><%=listing.description %></li>
        <li> <span>&#2547; </span> <%=listing.price.toLocaleString("en-In") %></li>
        <li><%=listing.location %></li>
        <li><%=listing.country %></li>
    </ul>
    <br>
    <a href="/listings/<%=listing.id %>/edit">Edit this listings</a>

    <br>
    <form method="post" action="/listings/<%=listing._id %>?_method=DELETE">
        <button>Delete this listings</button>
    </form>
</body>
