<% layout("/layouts/boilerplate") %>

<body>
  <div class="container mt-5 d-flex justify-content-center">
    <% if(listing) { %>
      <div class="card mb-3 listing-card" style="max-width: 750px; width: 100%;">
        <% if(listing.image && listing.image.url){ %>
          <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title || 'Listing Image' %>">
        <% } else { %>
          <img src="https://via.placeholder.com/800x400?text=No+Image" class="card-img-top" alt="No Image">
        <% } %>

        <div class="card-body px-4 py-3">
          <h3 class="card-title mb-3"><%= listing.title || 'No Title' %></h3>
          <p class="card-text mb-2">
            <b><i><%=listing.owner.username %></i></b>
            <br>
            <%= listing.description || 'No Description' %>
          </p>

          <p class="card-text mb-2">
            <strong>Price:</strong> <span>&#2547;</span> 
            <%= listing.price != null ? listing.price.toLocaleString("en-In") : '0' %>
          </p>

          <p class="card-text mb-3">
            <strong>Location:</strong> <%= listing.location || 'Unknown' %>, <%= listing.country || 'Unknown' %>
          </p>

          <div class="d-flex gap-2">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary">Edit Listing</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-danger">Delete Listing</button>
            </form>
          </div>
        </div>
      </div>
    <% } else { %>
      <p class="text-center">Listing not found.</p>
    <% } %>
  </div>

  <div class="col-8 offset-3">
    <hr>
    <h4>Leave a Review</h4>
    <form class="mb-3" action="/listings/<%= listing._id%>/reviews" method="POST" novalidate class="needs-validation">
      <div class="mb-3 mt-3">
        <label for="rating">Rating</label>
        <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
      </div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label><br>
        <textarea name="review[comment]" id="comment" cols="60"  rows="5" class="form-label" required></textarea>
        <div class="invalid-feedback">Please add some comment</div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>

    <hr>

    <p><b>All Reviews</b></p>
    <div class="row">
      <% for(review of listing.reviews){%>
        <div class="card col-5 ms-3 mb-3">
          <div class="card-body">
            <h5 class="card-title">Name</h5>
            <p class="card-text"><%=review.comment %></p>
            <p class="card-text"><%=review.rating %>Star</p>
          </div>

          <form class="mb-3"
                method="POST"
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button class="btn btn-sm btn-dark">delete</button>
          </form>
        </div>
      <% } %>
    </div>
    
  </div>
</body>