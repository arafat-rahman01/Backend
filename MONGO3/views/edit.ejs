<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZEdit your chat</title>
</head>
<body>
    <p>Edit your chat: <%=chat._id %></p>
    <p>This chat was sent from <b> <%=chat.from %> to <%=chat.to %></b> </p>

    <form method="post" action="/chats/<%=chat._id %>">
        <textarea name="msg" rows="5" cols="20"><%=chat.msg %></textarea>
        <button>Edit</button>
    </form>

</body>
</html>